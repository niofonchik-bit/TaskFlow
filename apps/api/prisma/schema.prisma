  color_presets_organizations_color_preset_idTocolor_presets color_presets?         @relation("organizations_color_preset_idTocolor_presets", fields: [color_preset_id], references: [id], onUpdate: NoAction)
  users_organizations_created_by_idTousers                   users?                 @relation("organizations_created_by_idTousers", fields: [created_by_id], references: [id], onUpdate: NoAction)
  users_organizations_owner_user_idTousers                   users                  @relation("organizations_owner_user_idTousers", fields: [owner_user_id], references: [id], onUpdate: NoAction)
  users_organizations_updated_by_idTousers                   users?                 @relation("organizations_updated_by_idTousers", fields: [updated_by_id], references: [id], onUpdate: NoAction)
  priorities                                                 priorities[]
  roles                                                      roles[]
  tags                                                       tags[]
  task_categories                                            task_categories[]
  task_events                                                task_events[]
  task_links                                                 task_links[]
  task_types                                                 task_types[]
  tasks                                                      tasks[]
  teams                                                      teams[]
}

model password_reset_tokens {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
